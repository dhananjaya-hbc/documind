# .env.example

# ============================================
# LLM Provider: "openrouter" (free) or "openai" (paid)
# ============================================
LLM_PROVIDER=openrouter

# OpenRouter (FREE) - Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# OpenAI (PAID) - Get key from https://platform.openai.com/api-keys

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=abc123xyz789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# ChromaDB
# ============================================
CHROMA_PERSIST_DIR=./chroma_data

# ============================================
# App
# ============================================
DEBUG=True